# ═══════════════════════════════════════════════════════════════════
# RoboMasterClient 发布配置（不要提交此文件；复制为 .release.env 并填写）
#
# 服务器侧需先准备（一次性）:
#   1. 确保 antientropy.xin 已指向服务器公网 IP 并配好 HTTPS 证书
#   2. 创建目录 /var/www/html/robomaster/  （或你选的 nginx root）
#   3. 配置 nginx location（参考本目录 nginx_robomaster.conf）
#   4. 在你的开发机 ~/.ssh/config 里配置好到服务器的 SSH Key 登录
# ═══════════════════════════════════════════════════════════════════

# rsync 目标（SSH 协议）
RSYNC_TARGET="user@antientropy.xin:/var/www/html/robomaster/"

# 可选：额外 SSH 参数（非标准端口/密钥路径等）
# RSYNC_SSH_OPTS="-p 22 -i ~/.ssh/id_ed25519"
